{
  "name": "praktiki",
  "version": "1.0",
  "type": "module",
  "exports": {
    "./_*.js": "./src/scripts/_*.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "compile": "node pug.config.js && sass --no-source-map src/styles:dist/styles && rollup --config rollup.config.js",
    "compress": "npm run compile && zip ./dist/* && mkdir compressed && mv ./dist/*.zip ./dist.zip",
    "pug": "node pug.config.js",
    "rollup": "rollup --watch --config rollup.config.js",
    "sass": "sass --no-source-map -w src/styles:dist/styles",
    "serve": "http-server ./dist -c-1 -o",
    "ship": "npm run compress"
  },
  "dependencies": {
    "dompurify": "^3.3.3",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "pdfjs-dist": "^5.7.284",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@types/pug": "^2.0.10",
    "@types/ttf2woff2": "^2.0.2",
    "chalk": "^5.6.2",
    "dotenv": "^17.4.2",
    "pug": "^3.0.4",
    "rollup": "^4.60.3",
    "sass": "^1.99.0",
    "ttf2woff2": "^8.0.1"
  }
}
